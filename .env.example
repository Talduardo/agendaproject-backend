# ── SERVIDOR ──────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── JWT ───────────────────────────────────────────
# Gere uma string longa e aleatória — ex: openssl rand -hex 32
JWT_SECRET=troque_por_string_aleatoria_longa
JWT_EXPIRES_IN=7d

# ── FIREBASE ADMIN (notificações push) ────────────
# Opção A: caminho para o arquivo baixado do Firebase Console
# Firebase Console → Configurações → Contas de serviço → Gerar nova chave privada
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Opção B: variáveis individuais (ideal para Railway/Render)
# FIREBASE_PROJECT_ID=seu-projeto
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu-projeto.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── AMBIENTE ──────────────────────────────────────
NODE_ENV=development
